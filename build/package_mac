#!/bin/bash
set -euo pipefail

APPNAME=mscore
LONG_NAME="MuseScore"
LONGER_NAME="MuseScore 3"
VERSION=0
CODESIGN_IDENTITY="${MACOS_CODESIGN_IDENTITY:-Developer ID Application: MuseScore}"
SKIP_CODESIGN="${MACOS_SKIP_CODESIGN:-0}"
DMG_SIZE="${MUSESCORE_DMG_SIZE:-}"
QT_PREFIX="${QT_PREFIX:-}"
MACDEPLOYQT="${MACDEPLOYQT:-}"

while [[ "$#" -gt 0 ]]; do
    case $1 in
        --long_name) LONG_NAME="$2"; shift ;;
        --longer_name) LONGER_NAME="$2"; shift ;;
        --version) VERSION=$2; shift ;;
        --sign_identity) CODESIGN_IDENTITY="$2"; shift ;;
        --skip_sign) SKIP_CODESIGN=1 ;;
        *) echo "Unknown parameter passed: $1"; exit 1 ;;
    esac
    shift
done

if [ "$VERSION" = "0" ]; then
    SCRIPT_DIR=$(cd "$(dirname ${BASH_SOURCE[0]})" && pwd)
    VERSION=$(cmake -P "$SCRIPT_DIR/../config.cmake" | sed -n -e "s/^.*VERSION  *//p")
fi    

if [ -z "$QT_PREFIX" ] && command -v brew >/dev/null 2>&1; then
    QT_PREFIX="$(brew --prefix qt@5 2>/dev/null || true)"
fi

if [ -z "$MACDEPLOYQT" ]; then
    if [ -n "$QT_PREFIX" ]; then
        MACDEPLOYQT="${QT_PREFIX}/bin/macdeployqt"
    else
        MACDEPLOYQT="$(command -v macdeployqt 2>/dev/null || true)"
    fi
fi

if [ -z "$MACDEPLOYQT" ] || [ ! -x "$MACDEPLOYQT" ]; then
    echo "Qt 5 macdeployqt was not found; set QT_PREFIX or MACDEPLOYQT" >&2
    exit 1
fi

QT_BIN_DIR="$(cd "$(dirname "$MACDEPLOYQT")" && pwd)"
QT_QMAKE="${QT_BIN_DIR}/qmake"
if [ ! -x "$QT_QMAKE" ]; then
    echo "qmake was not found next to macdeployqt: ${QT_QMAKE}" >&2
    exit 1
fi

QT_VERSION="$($QT_QMAKE -query QT_VERSION)"
case "$QT_VERSION" in
    5.*) ;;
    *)
        echo "MuseScore 3 packaging requires Qt 5 macdeployqt; found Qt ${QT_VERSION}: ${MACDEPLOYQT}" >&2
        exit 1
        ;;
esac

echo "LONG_NAME: $LONG_NAME"
echo "LONGER_NAME: $LONGER_NAME"
echo "VERSION: $VERSION"
echo "CODESIGN_IDENTITY: $CODESIGN_IDENTITY"
echo "SKIP_CODESIGN: $SKIP_CODESIGN"
echo "MACDEPLOYQT: $MACDEPLOYQT (Qt $QT_VERSION)"

WORKING_DIRECTORY=applebuild
BACKGROUND=build/packaging/musescore-dmg-background.tiff
APP_PATH=applebuild/${APPNAME}.app

VOLNAME=${LONG_NAME}-${VERSION}
DMGNAME=${VOLNAME}Uncompressed.dmg
COMPRESSEDDMGNAME=${VOLNAME}.dmg
DEV=""
VOLUME=""

function cleanup_mount() {
    if [ -n "${VOLUME:-}" ] && [ -d "$VOLUME" ]; then
        hdiutil detach "$VOLUME" >/dev/null 2>&1 || true
    fi
}

trap cleanup_mount EXIT


function set_bundle_display_options() {
	osascript <<-EOF
    tell application "Finder"
        set f to POSIX file ("${1}" as string) as alias
        tell folder f
            open
            tell container window
                set toolbar visible to false
                set statusbar visible to false
                set current view to icon view
                delay 1 -- sync
                set the bounds to {0, 0, 540, 345}
            end tell
            delay 1 -- sync
            set icon size of the icon view options of container window to 128
            set arrangement of the icon view options of container window to not arranged
            set position of item "${LONGER_NAME}.app" to {400,110}
            close
            set position of item "Applications" to {150,110}
            open
            set background picture of the icon view options of container window to file "background.tiff" of folder "Pictures"
            set the bounds of the container window to {0, 0, 540, 345}
            update without registering applications
            delay 5 -- sync
            close
        end tell
        delay 5 -- sync
    end tell
EOF

}

function change_rpath() {
   for P in `otool -L "$1" | awk '{print $1}'`
   do
      if [[ "$P" == *@rpath* ]]
      then
         if [[ "$P" == *Qt* ]]
         then
            PSLASH=$(echo "$P" | sed 's,@rpath,@loader_path/../Frameworks,g')
            FNAME=$(echo "$P" | sed "s,@rpath,${VOLUME}/${APPNAME}.app/Contents/Frameworks,g")
            install_name_tool -change "$P" "$PSLASH" "$1"
            for P1 in `otool -L "$FNAME" | awk '{print $1}'`
            do
               if [[ "$P1" == *@rpath* ]]
               then
                   PSLASH1=$(echo "$P1" | sed "s,@rpath,@loader_path/../../..,g")
                   install_name_tool -change "$P1" "$PSLASH1" "$FNAME"
               fi
            done
         else
            PSLASH=$(echo "$P" | sed 's,@rpath,@executable_path/../Frameworks,g')
            FNAME=$(echo "$P" | sed "s,@rpath,${VOLUME}/${APPNAME}.app/Contents/Frameworks,g")
            install_name_tool -change "$P" "$PSLASH" "$1"
         fi
      fi
   done
}

function change_rpath_QWebEngine() {
   for P in `otool -L "$1" | awk '{print $1}'`
   do
      if [[ "$P" == *@rpath* ]]
      then
         PSLASH=$(echo "$P" | sed 's,@rpath,@loader_path/../../../../../../..,g')
         FNAME=$(echo "$P" | sed "s,@rpath,${VOLUME}/${APPNAME}.app/Contents/Frameworks,g")
         install_name_tool -change "$P" "$PSLASH" "$1"
      fi
   done
}

function sign_resource_macho_files() {
  local identity="$1"
  local runtime_options="$2"
  local resources_dir="$3"

  if [ ! -d "$resources_dir" ]; then
    return
  fi

  while IFS= read -r -d '' f
  do
    if file "$f" | grep -q "Mach-O"; then
      if [ "$runtime_options" = "1" ]; then
        codesign --force --options runtime -s "$identity" "$f"
      else
        codesign --force -s "$identity" "$f"
      fi
    fi
  done < <(find "$resources_dir" -type f -print0)
}

function verify_resource_macho_files() {
  local resources_dir="$1"

  if [ ! -d "$resources_dir" ]; then
    return
  fi

  while IFS= read -r -d '' f
  do
    if file "$f" | grep -q "Mach-O"; then
      codesign --verify --strict --verbose=2 "$f"
    fi
  done < <(find "$resources_dir" -type f -print0)
}

for mount_point in /Volumes/"${VOLNAME}" /Volumes/"${VOLNAME}"\ *; do
  if [ -e "$mount_point" ]; then
    hdiutil detach "$mount_point" || true
  fi
done

rm -f "${WORKING_DIRECTORY}/${COMPRESSEDDMGNAME}"
rm -f "${WORKING_DIRECTORY}/${DMGNAME}"

# macdeployqt and install_name_tool rewrite binaries in place and temporarily
# need substantially more space than the final compressed image occupies.
if [ -z "$DMG_SIZE" ]; then
    APP_SIZE_KB=$(du -sk "$APP_PATH" | awk '{print $1}')
    APP_SIZE_MB=$(((APP_SIZE_KB + 1023) / 1024))
    DMG_SIZE_MB=$((APP_SIZE_MB * 2 + 512))
    if [ "$DMG_SIZE_MB" -lt 2048 ]; then
        DMG_SIZE_MB=2048
    fi
    DMG_SIZE="${DMG_SIZE_MB}m"
fi
echo "Temporary DMG size: $DMG_SIZE"
hdiutil create -size "$DMG_SIZE" -fs HFS+ -volname "${VOLNAME}" "${WORKING_DIRECTORY}/${DMGNAME}"

# Mount the disk image once. hdiutil may auto-number duplicate /Volumes mounts
# (for example "/Volumes/MuseScore-3.6.2 1"), so preserve the full tab-delimited
# mount path from hdiutil instead of parsing `mount` output by spaces.
ATTACH_OUTPUT=$(hdiutil attach -readwrite "${WORKING_DIRECTORY}/${DMGNAME}")
DEV=$(echo "${ATTACH_OUTPUT}" | awk -F '\t' '/Apple_HFS/ { print $1; exit }')
VOLUME=$(echo "${ATTACH_OUTPUT}" | awk -F '\t' '/Apple_HFS/ { print $3; exit }')
if [ -z "${DEV}" ] || [ -z "${VOLUME}" ]; then
  echo "Unable to determine mounted DMG device or mount point"
  echo "${ATTACH_OUTPUT}"
  exit 1
fi

# copy in the application bundle
cp -Rp "${APP_PATH}" "${VOLUME}/${APPNAME}.app"
if [ ! -d "${VOLUME}/${APPNAME}.app" ]; then
  echo "Unable to copy app bundle to ${VOLUME}/${APPNAME}.app"
  hdiutil detach "$VOLUME"
  exit 1
fi

# delete unused stuff
rm -rf "${VOLUME}/${APPNAME}.app/Contents/PlugIns/mediaservice"
rm -rf "${VOLUME}/${APPNAME}.app/Contents/PlugIns/audio"
rm -rf "${VOLUME}/${APPNAME}.app/Contents/PlugIns/sqldrivers"

rm -rf "${VOLUME}/${APPNAME}.app/Contents/Frameworks/Enginio".*
rm -rf "${VOLUME}/${APPNAME}.app/Contents/Frameworks/QtBluetooth".*
rm -rf "${VOLUME}/${APPNAME}.app/Contents/Frameworks/QtNfc".*
rm -rf "${VOLUME}/${APPNAME}.app/Contents/Frameworks/QtLocation".*
rm -rf "${VOLUME}/${APPNAME}.app/Contents/Frameworks/QtPurchasing".*
rm -rf "${VOLUME}/${APPNAME}.app/Contents/Frameworks/QtQuickParticles".*

rm -rf "${VOLUME}/${APPNAME}.app/Contents/Resources/qml/Enginio"
rm -rf "${VOLUME}/${APPNAME}.app/Contents/Resources/qml/QtBluetooth"
rm -rf "${VOLUME}/${APPNAME}.app/Contents/Resources/qml/QtNfc"
rm -rf "${VOLUME}/${APPNAME}.app/Contents/Resources/qml/QtLocation"
rm -rf "${VOLUME}/${APPNAME}.app/Contents/Resources/qml/QtPositioning"
rm -rf "${VOLUME}/${APPNAME}.app/Contents/Resources/qml/QtPurchasing"
rm -rf "${VOLUME}/${APPNAME}.app/Contents/Resources/qml/QtQuick/Particles"*
rm -rf "${VOLUME}/${APPNAME}.app/Contents/Resources/qml/Qt/WebSockets"

find "${VOLUME}/${APPNAME}.app/Contents" -type d -name "*.dSYM" -exec rm -r {} +

#homebrew libs may not be writable force it?
BREW_CELLAR=$(brew --cellar 2>/dev/null || true)
if [ -n "$BREW_CELLAR" ] && [ -d "$BREW_CELLAR" ]; then
  chmod -R +w "$BREW_CELLAR" || true
fi
"$MACDEPLOYQT" "${VOLUME}/${APPNAME}.app" -always-overwrite

DEPLOYED_APP="${VOLUME}/${APPNAME}.app"
DEPLOYED_BIN="${DEPLOYED_APP}/Contents/MacOS/mscore"
QT5_CORE="${DEPLOYED_APP}/Contents/Frameworks/QtCore.framework/Versions/5/QtCore"
if ! file "$DEPLOYED_BIN" | grep -q "Mach-O"; then
  echo "Packaging failed: deployed executable is not Mach-O: $DEPLOYED_BIN" >&2
  exit 1
fi
if [ ! -f "$QT5_CORE" ]; then
  echo "Packaging failed: Qt 5 Core framework was not deployed: $QT5_CORE" >&2
  exit 1
fi
if find "${DEPLOYED_APP}/Contents/Frameworks" -path "*/Versions/6/*" -print -quit | grep -q .; then
  echo "Packaging failed: Qt 6 frameworks were mixed into the Qt 5 application" >&2
  exit 1
fi

# fix the libs, qt5.6 has @rpath...
BIN_FILE=${VOLUME}/${APPNAME}.app/Contents/MacOS/mscore
change_rpath "$BIN_FILE"
# fix the QWebEngineProcess, qt5.9 has @rpath...
WEBENGINE_PROCESS_CANDIDATES=(
  "${VOLUME}/${APPNAME}.app/Contents/Frameworks/QtWebEngineCore.framework/Versions/5/Helpers/QtWebEngineProcess.app/Contents/MacOS/QtWebEngineProcess"
  "${VOLUME}/${APPNAME}.app/Contents/Frameworks/QtWebEngineCore.framework/Helpers/QtWebEngineProcess.app/Contents/MacOS/QtWebEngineProcess"
)
WebEngineProcess=""
for candidate in "${WEBENGINE_PROCESS_CANDIDATES[@]}"; do
  if [ -f "$candidate" ]; then
    WebEngineProcess="$candidate"
    break
  fi
done
if [ -n "$WebEngineProcess" ]; then
  change_rpath_QWebEngine "$WebEngineProcess"
else
  echo "QtWebEngineProcess not found; skip WebEngine rpath fix"
fi

# Workaround:
# fix Homebrew libraries with hard coded absolute path, see QTBUG-56814
FOLDER_NAME=${VOLUME}/${APPNAME}.app/Contents/Frameworks
if [ -n "$BREW_CELLAR" ]; then
  while IFS= read -r P
  do
      for P1 in `otool -L "$P" | awk '{print $1}'`
      do
          if [[ "$P1" == "$BREW_CELLAR"/* && "$P1" == *.dylib ]]
          then
              PATHNAME=$(dirname $P1)
              PSLASH1=$(echo $P1 | sed "s,$PATHNAME,@executable_path/../Frameworks,g")
              install_name_tool -change $P1 $PSLASH1 "$P"
          fi
      done
  done < <(find "$FOLDER_NAME" -maxdepth 1 -type f -name "*.dylib")
fi

while IFS= read -r -d '' f
do
  lipo -remove ppc7400 "$f" -output "$f" > /dev/null 2>&1 || true
  lipo -remove x86 "$f" -output "$f" > /dev/null 2>&1 || true
  lipo -remove ppc "$f" -output "$f" > /dev/null 2>&1 || true
done < <(find "${VOLUME}/${APPNAME}.app/Contents" -iname "*" -print0)

otool -L "${VOLUME}/${APPNAME}.app/Contents/MacOS/mscore"
if [ -n "$WebEngineProcess" ]; then
  otool -L "$WebEngineProcess"
fi

echo "Rename ${APPNAME}.app to ${VOLUME}/${LONGER_NAME}.app"
mv "${VOLUME}/${APPNAME}.app" "${VOLUME}/${LONGER_NAME}.app"


echo "Copy in background image"
# copy in background image
mkdir -p "${VOLUME}/Pictures"
# fixme: path
cp "${BACKGROUND}" "${VOLUME}/Pictures/background.tiff"

echo "symlink application"
# nssymlink application
ln -s /Applications/ "${VOLUME}/Applications"
set_bundle_display_options "${VOLUME}"
mv "${VOLUME}/Pictures" "${VOLUME}/.Pictures"

# Most nested locations should go first
CODE_PATHS=(
    "${VOLUME}/${LONGER_NAME}.app"
)
SPARKLE_AUTOUPDATE="${VOLUME}/${LONGER_NAME}.app/Contents/Frameworks/Sparkle.framework/Versions/A/Resources/Autoupdate.app"
if [ -d "$SPARKLE_AUTOUPDATE" ]; then
  CODE_PATHS=("$SPARKLE_AUTOUPDATE" "${CODE_PATHS[@]}")
fi
WEBENGINE_SIGN_PATH="${VOLUME}/${LONGER_NAME}.app/Contents/Frameworks/QtWebEngineCore.framework/Helpers/QtWebEngineProcess.app/Contents/MacOS/QtWebEngineProcess"
APP_BUNDLE="${VOLUME}/${LONGER_NAME}.app"
APP_RESOURCES="${APP_BUNDLE}/Contents/Resources"

if [[ "$SKIP_CODESIGN" == "1" || "$SKIP_CODESIGN" == "ON" || "$SKIP_CODESIGN" == "TRUE" ]]; then
  # Apple Silicon still requires a coherent code signature. When Developer ID
  # signing is skipped, seal the bundle with an ad-hoc signature so local
  # installs do not crash with CODESIGNING Invalid Page at launch.
  echo "Ad-hoc codesign"
  codesign --force --deep -s - "${CODE_PATHS[@]}"
  if [ -f "$WEBENGINE_SIGN_PATH" ]; then
    codesign --force --deep --sign - "$WEBENGINE_SIGN_PATH"
  fi
  # QML plugins live under Contents/Resources, where codesign --deep is not
  # reliable. Sign them after the deep pass, then reseal only the outer bundle.
  sign_resource_macho_files "-" "0" "$APP_RESOURCES"
  codesign --force -s - "$APP_BUNDLE"
  echo "Codesign verify"
  codesign --verify --deep --strict --verbose=2 "${CODE_PATHS[@]}"
  verify_resource_macho_files "$APP_RESOURCES"
else
  #codesign
  echo "Developer ID codesign"
  # Sign code in other (more conventional) locations
  codesign --force --options runtime --entitlements "${WORKING_DIRECTORY}/../build/macosx_entitlements.plist" --deep -s "$CODESIGN_IDENTITY" "${CODE_PATHS[@]}"
  # Sign QtWebEngine application for MacOS Catalina
  if [ -f "$WEBENGINE_SIGN_PATH" ]; then
    codesign --force --verify --verbose --options runtime --entitlements "${WORKING_DIRECTORY}/../build/qtwebengineprocess.entitlements" --deep --sign "$CODESIGN_IDENTITY" "$WEBENGINE_SIGN_PATH"
  fi
  # QML plugins live under Contents/Resources, where codesign --deep is not
  # reliable. Sign them after the deep pass, then reseal only the outer bundle.
  sign_resource_macho_files "$CODESIGN_IDENTITY" "1" "$APP_RESOURCES"
  codesign --force --options runtime --entitlements "${WORKING_DIRECTORY}/../build/macosx_entitlements.plist" -s "$CODESIGN_IDENTITY" "$APP_BUNDLE"
  echo "spctl"
  spctl --assess --type execute "$APP_BUNDLE" || echo "Warning: Gatekeeper assessment did not accept the app; notarization may still be required"
  echo "Codesign verify"
  codesign --verify --deep --strict --verbose=2 "${CODE_PATHS[@]}"
  verify_resource_macho_files "$APP_RESOURCES"
fi

if [ ! -d "$APP_BUNDLE" ]; then
  echo "Packaging failed: missing app bundle at $APP_BUNDLE"
  hdiutil detach "$VOLUME"
  exit 1
fi

echo "Unmount"
# Unmount the disk image
hdiutil detach "$VOLUME" || exit 1
VOLUME=""

# Convert the disk image to read-only
hdiutil convert "${WORKING_DIRECTORY}/${DMGNAME}" -format UDBZ -o "${WORKING_DIRECTORY}/${COMPRESSEDDMGNAME}" || exit 1

shasum -a 256 "${WORKING_DIRECTORY}/${COMPRESSEDDMGNAME}" || exit 1

rm "${WORKING_DIRECTORY}/${DMGNAME}"
