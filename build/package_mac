#!/bin/bash

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
APPNAME=mscore
LONG_NAME="MuseScore"
LONGER_NAME="MuseScore 3"
VERSION=0
CODESIGN_IDENTITY="${MACOS_CODESIGN_IDENTITY:-Developer ID Application: MuseScore}"
SKIP_CODESIGN="${MACOS_SKIP_CODESIGN:-0}"

while [[ "$#" -gt 0 ]]; do
    case $1 in
        --long_name) LONG_NAME="$2"; shift ;;
        --longer_name) LONGER_NAME="$2"; shift ;;
        --version) VERSION=$2; shift ;;
        --sign_identity) CODESIGN_IDENTITY="$2"; shift ;;
        --skip_sign) SKIP_CODESIGN=1 ;;
        *) echo "Unknown parameter passed: $1"; exit 1 ;;
    esac
    shift
done

if [ "$VERSION" = "0" ]; then
    VERSION=$(cmake -P "$SCRIPT_DIR/../config.cmake" | sed -n -e "s/^.*VERSION  *//p")
fi    

echo "LONG_NAME: $LONG_NAME"
echo "LONGER_NAME: $LONGER_NAME"
echo "VERSION: $VERSION"
echo "CODESIGN_IDENTITY: $CODESIGN_IDENTITY"
echo "SKIP_CODESIGN: $SKIP_CODESIGN"

WORKING_DIRECTORY=applebuild
BACKGROUND=build/packaging/musescore-dmg-background.tiff
APP_PATH=applebuild/${APPNAME}.app
APP_CONTENTS=${APP_PATH}/Contents
APP_BINARY=${APP_CONTENTS}/MacOS/mscore

VOLNAME=${LONG_NAME}-${VERSION}
DMGNAME=${VOLNAME}Uncompressed.dmg
COMPRESSEDDMGNAME=${VOLNAME}.dmg

if [ ! -x "${APP_BINARY}" ]; then
  echo "Packaging requires an installed application bundle: missing ${APP_BINARY}"
  exit 1
fi

# Deployment and verification belong to the build pipeline. Refuse an
# undeployed bundle here so the DMG stage never tries to repair or replace its
# selected Qt runtime.
for required_path in \
  "${APP_CONTENTS}/Resources/qt.conf" \
  "${APP_CONTENTS}/Frameworks/QtCore.framework" \
  "${APP_CONTENTS}/PlugIns/platforms/libqcocoa.dylib"
do
  if [ ! -e "${required_path}" ]; then
    echo "Packaging requires a deployed and verified application bundle: missing ${required_path}"
    exit 1
  fi
done

VERIFY_ARGS=(
  --app "${APP_PATH}"
  --skip-signature
)
XEN_TUNER_ROOT="${APP_CONTENTS}/Resources/plugins/musescore-xen-tuner"
XEN_TUNER_MANIFEST="${APP_CONTENTS}/Resources/plugins/musescore-xen-tuner.runtime.manifest"
if [ -d "${XEN_TUNER_ROOT}" ]; then
  if [ ! -f "${XEN_TUNER_MANIFEST}" ]; then
    echo "Packaging requires the installed Xen Tuner runtime manifest: ${XEN_TUNER_MANIFEST}"
    exit 1
  fi
  VERIFY_ARGS+=(--require-xen-tuner --xen-manifest "${XEN_TUNER_MANIFEST}")
elif [ -f "${XEN_TUNER_MANIFEST}" ]; then
  echo "Packaging found a stale Xen Tuner manifest without its runtime: ${XEN_TUNER_MANIFEST}"
  exit 1
fi
"${SCRIPT_DIR}/../scripts/verify_macos_app.sh" "${VERIFY_ARGS[@]}"


function set_bundle_display_options() {
	osascript <<-EOF
    tell application "Finder"
        set f to POSIX file ("${1}" as string) as alias
        tell folder f
            open
            tell container window
                set toolbar visible to false
                set statusbar visible to false
                set current view to icon view
                delay 1 -- sync
                set the bounds to {0, 0, 540, 345}
            end tell
            delay 1 -- sync
            set icon size of the icon view options of container window to 128
            set arrangement of the icon view options of container window to not arranged
            set position of item "${LONGER_NAME}.app" to {400,110}
            close
            set position of item "Applications" to {150,110}
            open
            set background picture of the icon view options of container window to file "background.tiff" of folder "Pictures"
            set the bounds of the container window to {0, 0, 540, 345}
            update without registering applications
            delay 5 -- sync
            close
        end tell
        delay 5 -- sync
    end tell
EOF

}

function sign_resource_macho_files() {
  local identity="$1"
  local runtime_options="$2"
  local resources_dir="$3"

  if [ ! -d "$resources_dir" ]; then
    return
  fi

  while IFS= read -r -d '' f
  do
    if file "$f" | grep -q "Mach-O"; then
      if [ "$runtime_options" = "1" ]; then
        codesign --force --options runtime -s "$identity" "$f"
      else
        codesign --force -s "$identity" "$f"
      fi
    fi
  done < <(find "$resources_dir" -type f -print0)
}

function verify_resource_macho_files() {
  local resources_dir="$1"

  if [ ! -d "$resources_dir" ]; then
    return
  fi

  while IFS= read -r -d '' f
  do
    if file "$f" | grep -q "Mach-O"; then
      codesign --verify --strict --verbose=2 "$f"
    fi
  done < <(find "$resources_dir" -type f -print0)
}

for mount_point in /Volumes/"${VOLNAME}" /Volumes/"${VOLNAME}"\ *; do
  if [ -e "$mount_point" ]; then
    hdiutil detach "$mount_point" || true
  fi
done

rm -f "${WORKING_DIRECTORY}/${COMPRESSEDDMGNAME}"
rm -f "${WORKING_DIRECTORY}/${DMGNAME}"

#tip: increase the size if the verified application bundle no longer fits
hdiutil create -size 500m -fs HFS+ -volname "${VOLNAME}" "${WORKING_DIRECTORY}/${DMGNAME}"

# Mount the disk image once. hdiutil may auto-number duplicate /Volumes mounts
# (for example "/Volumes/MuseScore-3.6.2 1"), so preserve the full tab-delimited
# mount path from hdiutil instead of parsing `mount` output by spaces.
ATTACH_OUTPUT=$(hdiutil attach -readwrite "${WORKING_DIRECTORY}/${DMGNAME}")
DEV=$(echo "${ATTACH_OUTPUT}" | awk -F '\t' '/Apple_HFS/ { print $1; exit }')
VOLUME=$(echo "${ATTACH_OUTPUT}" | awk -F '\t' '/Apple_HFS/ { print $3; exit }')
if [ -z "${DEV}" ] || [ -z "${VOLUME}" ]; then
  echo "Unable to determine mounted DMG device or mount point"
  echo "${ATTACH_OUTPUT}"
  exit 1
fi

# Copy the already deployed and verified application bundle without pruning,
# redeploying, thinning, or rewriting its Qt runtime.
APP_BUNDLE="${VOLUME}/${LONGER_NAME}.app"
if ! cp -Rp "${APP_PATH}" "${APP_BUNDLE}"; then
  echo "Unable to copy app bundle to ${APP_BUNDLE}"
  hdiutil detach "$VOLUME"
  exit 1
fi
if [ ! -d "${APP_BUNDLE}" ]; then
  echo "Unable to copy app bundle to ${APP_BUNDLE}"
  hdiutil detach "$VOLUME"
  exit 1
fi


echo "Copy in background image"
# copy in background image
mkdir -p "${VOLUME}/Pictures"
# fixme: path
cp "${BACKGROUND}" "${VOLUME}/Pictures/background.tiff"

echo "symlink application"
# nssymlink application
ln -s /Applications/ "${VOLUME}/Applications"
set_bundle_display_options "${VOLUME}"
mv "${VOLUME}/Pictures" "${VOLUME}/.Pictures"

# Most nested locations should go first
CODE_PATHS=(
    "${APP_BUNDLE}"
)
SPARKLE_AUTOUPDATE="${APP_BUNDLE}/Contents/Frameworks/Sparkle.framework/Versions/A/Resources/Autoupdate.app"
if [ -d "$SPARKLE_AUTOUPDATE" ]; then
  CODE_PATHS=("$SPARKLE_AUTOUPDATE" "${CODE_PATHS[@]}")
fi
WEBENGINE_SIGN_PATH="${APP_BUNDLE}/Contents/Frameworks/QtWebEngineCore.framework/Helpers/QtWebEngineProcess.app/Contents/MacOS/QtWebEngineProcess"
APP_RESOURCES="${APP_BUNDLE}/Contents/Resources"

if [[ "$SKIP_CODESIGN" == "1" || "$SKIP_CODESIGN" == "ON" || "$SKIP_CODESIGN" == "TRUE" ]]; then
  # Apple Silicon still requires a coherent code signature. When Developer ID
  # signing is skipped, seal the bundle with an ad-hoc signature so local
  # installs do not crash with CODESIGNING Invalid Page at launch.
  echo "Ad-hoc codesign"
  codesign --force --deep -s - "${CODE_PATHS[@]}"
  if [ -f "$WEBENGINE_SIGN_PATH" ]; then
    codesign --force --deep --sign - "$WEBENGINE_SIGN_PATH"
  fi
  # QML plugins live under Contents/Resources, where codesign --deep is not
  # reliable. Sign them after the deep pass, then reseal only the outer bundle.
  sign_resource_macho_files "-" "0" "$APP_RESOURCES"
  codesign --force -s - "$APP_BUNDLE"
  echo "Codesign verify"
  codesign --verify --deep --strict --verbose=2 "${CODE_PATHS[@]}"
  verify_resource_macho_files "$APP_RESOURCES"
else
  #codesign
  echo "Developer ID codesign"
  # Sign code in other (more conventional) locations
  codesign --force --options runtime --entitlements "${WORKING_DIRECTORY}/../build/macosx_entitlements.plist" --deep -s "$CODESIGN_IDENTITY" "${CODE_PATHS[@]}"
  # Sign QtWebEngine application for MacOS Catalina
  if [ -f "$WEBENGINE_SIGN_PATH" ]; then
    codesign --force --verify --verbose --options runtime --entitlements "${WORKING_DIRECTORY}/../build/qtwebengineprocess.entitlements" --deep --sign "$CODESIGN_IDENTITY" "$WEBENGINE_SIGN_PATH"
  fi
  # QML plugins live under Contents/Resources, where codesign --deep is not
  # reliable. Sign them after the deep pass, then reseal only the outer bundle.
  sign_resource_macho_files "$CODESIGN_IDENTITY" "1" "$APP_RESOURCES"
  codesign --force --options runtime --entitlements "${WORKING_DIRECTORY}/../build/macosx_entitlements.plist" -s "$CODESIGN_IDENTITY" "$APP_BUNDLE"
  echo "spctl"
  spctl --assess --type execute "$APP_BUNDLE"
  echo "Codesign verify"
  codesign --verify --deep --strict --verbose=2 "${CODE_PATHS[@]}"
  verify_resource_macho_files "$APP_RESOURCES"
fi

if [ ! -d "$APP_BUNDLE" ]; then
  echo "Packaging failed: missing app bundle at $APP_BUNDLE"
  hdiutil detach "$VOLUME"
  exit 1
fi

echo "Unmount"
# Unmount the disk image
hdiutil detach "$VOLUME" || exit 1

# Convert the disk image to read-only
hdiutil convert "${WORKING_DIRECTORY}/${DMGNAME}" -format UDBZ -o "${WORKING_DIRECTORY}/${COMPRESSEDDMGNAME}" || exit 1

shasum -a 256 "${WORKING_DIRECTORY}/${COMPRESSEDDMGNAME}" || exit 1

rm "${WORKING_DIRECTORY}/${DMGNAME}"
